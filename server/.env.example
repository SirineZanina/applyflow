# Frontend origin (for CORS — must match the URL the browser uses)
FRONTEND_URL=http://localhost:3000

# Database (Postgres)
DB_URL=your-db-host
DB_PORT=your-db-port
DB_NAME=your-db-name
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password

# Adzuna job ingestion (free tier — register at https://developer.adzuna.com)
# Set ADZUNA_ENABLED=true to activate the 30-min polling scheduler.
ADZUNA_ENABLED=false
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_API_KEY=your-adzuna-api-key
# ISO country code for Adzuna search (gb, fr, de, us…). Defaults to gb.
# ADZUNA_COUNTRY=gb

# AI provider — active provider is set by ai.provider in application.yml.
# Preferred: set a single key consumed by configuration fallback:
AI_API_KEY=your-ai-api-key
# Provider-specific alternatives (optional):
# Gemini (free tier — get key at https://aistudio.google.com/app/apikey):
# GEMINI_API_KEY=your-gemini-api-key

# To use Anthropic instead: set ai.provider=anthropic in application.yml and set:
# ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional — override the model for the active provider (defaults defined in application.yml):
# AI_MODEL=gemini-2.0-flash

# Object storage (S3-compatible; MinIO for dev)
S3_ENDPOINT=your-s3-endpoint
S3_REGION=your-s3-region
S3_BUCKET=your-s3-bucket
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key

# Mail (MailHog for dev)
SMTP_HOST=your-smtp-host
SMTP_PORT=your-smtp-port
MAIL_FROM=your-mail-from-address

# JWT signing keys (filesystem paths; NEVER put keys inside src/main/resources)
# Dev default resolves to ./keys/local-only/*.pem (repo-local, gitignored).
# Generate with:
#   mkdir -p server/keys/local-only && cd server/keys/local-only
#   openssl genpkey -algorithm RSA -out private_key.pem -pkeyopt rsa_keygen_bits:4096
#   openssl rsa -in private_key.pem -pubout -out public_key.pem
# Prod: load from secret manager (AWS Secrets Manager / Vault / k8s Secret) and
# point these paths at the mounted file, or bind-mount a secret volume.
JWT_PRIVATE_KEY_PATH=./keys/local-only/private_key.pem
JWT_PUBLIC_KEY_PATH=./keys/local-only/public_key.pem

# JWT TTLs (milliseconds)
# Access token: default 24h in application.yml; production profile defaults to 15min.
# Refresh token: default 7 days.
JWT_ACCESS_TOKEN_EXPIRATION=86400000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

COOKIE_SECURE=use-secure-cookies-true-or-false